# Omnividence backend environment — copy to backend/.env and fill in.
# This file documents every OMNI_* var and the SerpApi key. Backend reads these only;
# none of them are exposed to the frontend (the frontend uses its own NEXT_PUBLIC_API_URL).

# --- SerpApi (shared by all three reverse-image-search providers) ---
# One key drives engines: google_lens, yandex_images, bing_images.
# If unset/empty, EVERY provider reports "provider not configured" and returns []
# (the pipeline still runs and reports the empty/not-configured state honestly —
# results are NEVER fabricated).
SERPAPI_KEY=

# --- Data directories ---
# Base data dir. Holds the SQLite DB, thumbnail cache, and InsightFace models.
# Created on startup if missing.
OMNI_DATA_DIR=./backend/data

# Full path to the SQLite file. Defaults to ${OMNI_DATA_DIR}/omnividence.db.
OMNI_DB_PATH=

# On-disk thumbnail cache dir. Files stored as <sha256(image_url)>.jpg.
# Defaults to ${OMNI_DATA_DIR}/thumbs.
OMNI_THUMB_CACHE_DIR=

# InsightFace model cache root (passed as root= to FaceAnalysis).
# buffalo_l downloads here once and persists. Defaults to ${OMNI_DATA_DIR}/models.
OMNI_INSIGHTFACE_ROOT=

# --- Tunables ---
# Max results returned per provider per page before ranking.
OMNI_MAX_RESULTS_PER_PAGE=20

# Per-thumbnail download timeout, in seconds.
OMNI_THUMB_TIMEOUT_SEC=10

# Comma-separated allowed CORS origins for the frontend.
OMNI_CORS_ORIGINS=http://localhost:3000
