# Omnividence — environment example.
# Copy to .env for the backend.  The frontend uses frontend/.env.local (see
# frontend/.env.local.example) because Next.js only exposes NEXT_PUBLIC_* vars.
#
# Nothing here is required to RUN the app. Providers (Yandex / Bing / Google
# Lens) use Scrapling's browser automation — there is NO API key to set. A
# blocked engine is skipped and reported honestly; results are never fabricated.

# --- Storage paths (all optional; sensible defaults shown) --------------------
# Base data dir. Holds the SQLite DB, thumbnail cache and InsightFace models.
# Created on startup if missing.
OMNI_DATA_DIR=./backend/data
# Full path to the SQLite file. Default: ${OMNI_DATA_DIR}/omnividence.db
# OMNI_DB_PATH=
# On-disk thumbnail cache dir. Default: ${OMNI_DATA_DIR}/thumbs
# OMNI_THUMB_CACHE_DIR=
# InsightFace model cache root (buffalo_l downloads here once on first run).
# Default: ${OMNI_DATA_DIR}/models
# OMNI_INSIGHTFACE_ROOT=

# --- Pipeline tuning (optional) -----------------------------------------------
# Max results returned per provider per page before ranking. Default: 20
# OMNI_MAX_RESULTS_PER_PAGE=20
# Per-thumbnail download timeout in seconds. Default: 10
# OMNI_THUMB_TIMEOUT_SEC=10
# Max upload size in bytes. Default: 10485760 (10 MB)
# OMNI_MAX_UPLOAD_BYTES=10485760

# --- CORS ---------------------------------------------------------------------
# Comma-separated allowed origins for the API. Default: http://localhost:3000
OMNI_CORS_ORIGINS=http://localhost:3000

# --- Frontend (set this in frontend/.env.local, not here) ---------------------
# Base URL of the FastAPI backend, read in the browser by the api client.
# NEXT_PUBLIC_API_URL=http://localhost:8000
